interface={{ interface }}
driver=nl80211
ssid={{ ssid }}

wpa_passphrase={{ password }}
wpa=2
wpa_key_mgmt=WPA-PSK
wpa_pairwise=CCMP
rsn_pairwise=CCMP
auth_algs=1

country_code=US
hw_mode={{ hw_mode }}
channel={{ channel }}

{% if security.client_isolation %}
ap_isolate=1
{% endif %}

{% if security.mode == "whitelist" and security.whitelist %}
macaddr_acl=1
accept_mac_file=/run/cordonnet/hostapd.accept
{% elif security.blacklist %}
macaddr_acl=0
deny_mac_file=/run/cordonnet/hostapd.deny
{% endif %}